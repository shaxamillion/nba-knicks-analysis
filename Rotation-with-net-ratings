             aes(x = MidPos, y = 0.05, label = Label, color = ShadeColor,
                 fill = ShadeColor),
             alpha = 0.12, label.size = 0.4, label.padding = unit(0.3, "lines"),
             fontface = "bold", size = 3.8, inherit.aes = FALSE) +
  
  # Re-draw label text on top (geom_label fill washes out text color)
