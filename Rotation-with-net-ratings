            aes(x = Possession, y = Player),
            fill = "white", alpha = 0.15, color = NA,
            width = 0.95, height = 0.4,
            position = position_nudge(y = 0.2)) +
  
  # ── 4. Net rating labels centered in each shaded region ───────────────────
