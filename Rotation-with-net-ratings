            aes(xmin = xmin, xmax = xmax, ymin = 0.5, ymax = 9.5,
                color = ShadeColor),
            fill = NA, linewidth = 0.6, linetype = "solid",
            alpha = 0.5, inherit.aes = FALSE) +
  
  # ── 3. Player tiles ───────────────────────────────────────────────────────
  # Drop shadow
  geom_tile(data = lineup_long,
            aes(x = Possession, y = Player, fill = Player),
            alpha = 0.25, color = NA, width = 0.98, height = 0.88,
            position = position_nudge(x = 0.15, y = -0.08)) +
  
  # Main tile
  geom_tile(data = lineup_long,
            aes(x = Possession, y = Player, fill = Player),
            color = "white", linewidth = 1.2, width = 0.95, height = 0.85,
            alpha = 0.95) +
  
