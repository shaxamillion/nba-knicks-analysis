# Net ratings lookup
lineup_net_ratings <- c(
  "Brunson-Hart-Bridges-OG-KAT"             = 1.3,
  "Alvarado-Bridges-OG-Diawara-KAT"         = 84.6,
  "Brunson-Shamet-Hart-OG-KAT"              = 1.4,
  "Brunson-Shamet-Hart-Diawara-Robinson"    = 98.2,
  "Brunson-Shamet-Bridges-Diawara-Robinson" = 31.0,
  "Brunson-Shamet-OG-Diawara-Robinson"      = 1.8,
  "Alvarado-Shamet-Bridges-KAT-Robinson"    = 16.7
)

normalize_lineup <- function(lineup) {
  paste(sort(strsplit(lineup, "-")[[1]]), collapse = "-")
}

normalized_ratings <- setNames(
  lineup_net_ratings,
  sapply(names(lineup_net_ratings), normalize_lineup)
)

parse_lineup <- function(lineup) {
  players <- strsplit(lineup, "-")[[1]]
  c(
    Brunson  = as.integer("Brunson"  %in% players),
    Alvarado = as.integer("Alvarado" %in% players),
    Shamet   = as.integer("Shamet"   %in% players),
    Hart     = as.integer("Hart"     %in% players),
    Bridges  = as.integer("Bridges"  %in% players),
    OG       = as.integer("OG"       %in% players),
    Diawara  = as.integer("Diawara"  %in% players),
    Robinson = as.integer("Robinson" %in% players),
    KAT      = as.integer("KAT"      %in% players)
  )
}

lineup_matrix <- t(sapply(lineups, parse_lineup))
lineup_data   <- as.data.frame(lineup_matrix)
lineup_data$Possession <- 1:nrow(lineup_data)
lineup_data$Lineup     <- lineups
lineup_data$NormLineup <- sapply(lineups, normalize_lineup)
lineup_data$NetRating  <- normalized_ratings[lineup_data$NormLineup]

# ── Build shaded region data ─────────────────────────────────────────────────
# Each contiguous run of the same lineup gets its own shaded block
lineup_data <- lineup_data %>%
  mutate(RunID = cumsum(c(1, diff(as.integer(factor(NormLineup))) != 0)))

region_data <- lineup_data %>%
  group_by(RunID, NormLineup, NetRating) %>%
  summarise(
    xmin = min(Possession) - 0.5,
    xmax = max(Possession) + 0.5,
    .groups = "drop"
  ) %>%
  filter(!is.na(NetRating)) %>%
  mutate(
    MidPos = (xmin + xmax) / 2,
    Label  = paste0(ifelse(NetRating >= 0, "+", ""), NetRating),
    # Shade color by tier
    ShadeColor = case_when(
      NetRating >= 50 ~ "#10B981",
      NetRating >= 15 ~ "#06B6D4",
      NetRating >= 0  ~ "#0051BA",
      TRUE            ~ "#EF4444"
    )
  )

# Long format for tiles
lineup_long <- lineup_data %>%
  select(-Lineup, -NormLineup, -NetRating, -RunID) %>%
  pivot_longer(cols = -Possession, names_to = "Player", values_to = "On_Court") %>%
  filter(On_Court == 1)

player_order <- c("Brunson", "Alvarado", "Shamet", "Hart",
                  "Bridges", "OG", "Diawara", "Robinson", "KAT")
lineup_long$Player <- factor(lineup_long$Player, levels = rev(player_order))

player_colors <- c(
  "Brunson"  = "#0051BA",
  "Alvarado" = "#A855F7",
  "Shamet"   = "#FF6B35",
  "Hart"     = "#06B6D4",
  "Bridges"  = "#10B981",
  "OG"       = "#EF4444",
  "Diawara"  = "#F59E0B",
  "Robinson" = "#14B8A6",
  "KAT"      = "#1E293B"
)

quarter_breaks <- c(16.5, 35.5, 54.5)

# ── Plot ─────────────────────────────────────────────────────────────────────
ggplot() +
  
  # ── 1. Shaded lineup regions (full grid height) ───────────────────────────
  geom_rect(data = region_data,
            aes(xmin = xmin, xmax = xmax, ymin = 0.5, ymax = 9.5,
                fill = ShadeColor),
            alpha = 0.08, inherit.aes = FALSE) +
  
  # ── 2. Colored border around each region ─────────────────────────────────
